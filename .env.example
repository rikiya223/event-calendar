# ── 環境変数のテンプレート ──
# 実際の値は .env に書く（.env は .gitignore 済み＝コミットされない）。
# Vercel では Project Settings → Environment Variables に同じキーを登録する。

# ── データベース（Supabase Postgres）──
# DATABASE_URL: アプリ実行時に使う「プール接続」(ポート 6543, ?pgbouncer=true)
# DIRECT_URL:   マイグレーション用の「直接接続」(ポート 5432)
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-x-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-x-region.pooler.supabase.com:5432/postgres"

# ── Supabase 認証（NEXT_PUBLIC_ はブラウザにも公開される＝公開してよい値）──
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ...（anon public key）"

# ── 管理者（カンマ区切り。ここに含まれるメールだけ /admin に入れる）──
ADMIN_EMAILS="you@example.com"

# ── 取り込みAPIの保護（/api/ingest/* を叩くときの合言葉。長いランダム文字列）──
INGEST_SECRET="（openssl rand -hex 32 などで生成）"

# ── 任意：映画公開日(TMDb)。無料枠は「非商用のみ」。収益化するなら使わない ──
TMDB_API_KEY=""

# ── 任意：AIによる半自動抽出（/api/ingest/ai）──
# ANTHROPIC_API_KEY=""
# AI_INGEST_MODEL="claude-opus-4-8"
